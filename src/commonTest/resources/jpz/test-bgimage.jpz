/><cells x="4" y="3" /><cells x="5" y="3" /></word><word id="4"><cells x="2" y="4" /><cells x="3" y="4" /><cells x="4" y="4" /><cells x="5" y="4" /></word><word id="5"><cells x="2" y="5" /><cells x="3" y="5" /><cells x="4" y="5" /><cells x="5" y="5" /></word><word id="1001"><cells x="1" y="1" /><cells x="1" y="2" /><cells x="1" y="3" /></word><word id="1002"><cells x="2" y="1" /><cells x="2" y="2" /><cells x="2" y="3" /><cells x="2" y="4" /><cells x="2" y="5" /></word><word id="1003"><cells x="3" y="1" /><cells x="3" y="2" /><cells x="3" y="3" /><cells x="3" y="4" /><cells x="3" y="5" /></word><word id="1004"><cells x="4" y="1" /><cells x="4" y="2" /><cells x="4" y="3" /><cells x="4" y="4" /><cells x="4" y="5" /></word><word id="1005"><cells x="5" y="3" /><cells x="5" y="4" /><cells x="5" y="5" /></word><clues><title><b>Across</b></title><clue word="1" number="1">First across clue with special characters αβγδε</clue><clue word="2" number="5">Second across clue</clue><clue word="3" number="6">Third across clue</clue><clue word="4" number="8">Fourth across clue</clue><clue word="5" number="9">Fifth across clue</clue></clues><clues><title><b>Down</b></title><clue word="1001" number="1">First down clue</clue><clue word="1002" number="2">Second down clue</clue><clue word="1003" number="3">Third down clue</clue><clue word="1004" number="4">Fourth down clue</clue><clue word="1005" number="7">Fifth down clue</clue></clues></crossword></rectangular-puzzle></crossword-compiler>